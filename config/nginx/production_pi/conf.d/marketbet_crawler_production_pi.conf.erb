upstream <%= config_base_name %>_server {
    server <%= server_target %>;
}

server {
    server_name <%= server_name %>;

    listen 80;
    
    location ~ \.(aspx|php|jsp|cgi|py|html|env(\..*)?|(aws|docker|git|github|gitlab|ssh|svn|well-known)(/.*)?|DS_Store|ya?ml|backup|bak|local|prod|production|less|save|sample|properties|log|old|lock|md)$|/(phpinfo|actuator|wp-content|wp-includes|static|public|gateway\;) {
        return 410;
    }

    root <%= server_public %>;

    location / {
        include includes/proxy.conf;
        proxy_pass http://<%= config_base_name %>_server;
    }

    location ~ ^/(assets|packs) {
        include includes/assets.conf;
    }
}
